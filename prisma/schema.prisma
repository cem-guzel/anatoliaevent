generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GalleryImage {
  id           String   @id @default(cuid())
  publicId     String   
  url          String   
  altText      String?  
  resourceType String   @default("image") // YENİ: Dosyanın video mu resim mi olduğunu tutacak
  createdAt    DateTime @default(now())
}